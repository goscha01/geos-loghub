# Grafana Cloud OTLP endpoint (from your Grafana Cloud stack)
GRAFANA_OTLP_LOGS_URL=https://otlp-gateway-prod-us-east-2.grafana.net/otlp/v1/logs

# Basic auth: echo -n "instanceId:apiToken" | base64
GRAFANA_OTLP_AUTH=Basic <base64(instanceId:apiKey)>

# Default environment label applied to logs
DEFAULT_ENV=prod

# JSON map of source → ingest key (clients must send x-loghub-key matching their source)
API_KEYS_JSON={"twilio":"TWILIO_INGEST_KEY_123","vercel":"VERCEL_INGEST_KEY_123","chrome":"CHROME_INGEST_KEY_123","railway":"RAILWAY_INGEST_KEY_123","supabase":"SUPABASE_INGEST_KEY_123"}

# Max request body size in KB (default 256)
MAX_BODY_KB=256

# Set to true to disable PII masking (phone numbers, emails)
ALLOW_PII=false

# Port (Railway sets this automatically)
PORT=3000
